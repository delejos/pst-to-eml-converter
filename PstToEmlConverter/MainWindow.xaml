<Window x:Class="PstToEmlConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PST → EML Converter" Height="620" Width="820" MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold"
                   Text="PST → EML Converter" Margin="0,0,0,12"/>

        <!-- Source selection -->
        <GroupBox Grid.Row="1" Header="Source" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="RbFile" Content="Single PST file" IsChecked="True" Margin="0,0,18,0"
                                 Checked="RbFile_Checked"/>
                    <RadioButton x:Name="RbFolder" Content="Folder with PST files"
                                 Checked="RbFolder_Checked"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Path:" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtSource" Grid.Row="1" Grid.Column="1" MinWidth="480" TextChanged="AnyPathChanged"/>
                <Button x:Name="BtnBrowseSource" Grid.Row="1" Grid.Column="2" Content="Browse…" Padding="14,6"
                        Margin="10,0,0,0" Click="BtnBrowseSource_Click"/>
            </Grid>
        </GroupBox>

        <!-- Destination -->
        <GroupBox Grid.Row="2" Header="Destination" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Output folder:" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtDest" Grid.Column="1" MinWidth="480" TextChanged="AnyPathChanged"/>
                <Button Grid.Column="2" Content="Browse…" Padding="14,6"
                        Margin="10,0,0,0" Click="BtnBrowseDest_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Options" Padding="10" Margin="0,0,0,12">
            <StackPanel>
                <CheckBox x:Name="ChkIncludeSubfolders"
                  Content="Include subfolders when scanning a folder"
                  IsChecked="True"
                  Margin="0,0,0,6"/>
                <CheckBox x:Name="ChkPreserveStructure"
                  Content="Preserve folder structure (mirror PST folders)"
                  IsChecked="True"
                  Margin="0,0,0,6"/>
                <CheckBox x:Name="ChkSkipExisting"
                  Content="Skip if output already exists"
                  IsChecked="False"/>
            </StackPanel>
        </GroupBox>

        <!-- Log -->
        <GroupBox Grid.Row="4" Header="Log" Padding="10">
            <DockPanel>
                <Button DockPanel.Dock="Top"
        Content="Clear log"
        MinWidth="90"
        HorizontalAlignment="Right"
        Padding="10,6"
        Margin="0,0,0,8"
        Click="BtnClearLog_Click"/>
                <TextBox x:Name="TxtLog"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"/>
            </DockPanel>
        </GroupBox>

        <!-- Footer controls -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="Progress" Height="16" VerticalAlignment="Center" Minimum="0" Maximum="100"/>

            <Button Grid.Column="1" x:Name="BtnStart" Content="Start" Padding="18,8"
                    Margin="12,0,0,0" Click="BtnStart_Click" IsEnabled="False"/>
            <Button Grid.Column="2" x:Name="BtnCancel" Content="Cancel" Padding="18,8"
                    Margin="10,0,0,0" Click="BtnCancel_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
